{
  "name": "world-cup-2026-predictor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js --host 127.0.0.1",
    "build": "node node_modules/typescript/bin/tsc --noEmit && node node_modules/vite/bin/vite.js build --base ./",
    "data:adapter": "node scripts/adapters/index.mjs",
    "data:odds:live": "node scripts/adapters/index.mjs --adapter odds-market --live --out imports/generated/odds-live.json",
    "data:compose": "node scripts/data-compose.mjs",
    "data:update": "node scripts/data-update.mjs",
    "preview": "node node_modules/vite/bin/vite.js preview --host 127.0.0.1",
    "test": "node --experimental-strip-types --test tests/*.test.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
